@model List<MonthlyStatement>

@{
    ViewData["Title"] = "My Statements";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <h2 class="mb-4">📄 My Payment Statements</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            No payment records found.
        </div>
    }
    else
    {
        <div class="card shadow-sm p-3">

            <table class="table table-striped table-hover align-middle">

                <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Reservation</th>
                    <th>Amount</th>
                    <th>Payment Date</th>
                    <th>Status</th>
                </tr>
                </thead>

                <tbody>

                @foreach (var s in Model)
                {
                    <tr>

                        <td>@s.MonthlyStatementId</td>

                        <td>#@s.ReservationId</td>

                        <td>
                            <strong>£@s.Amount.ToString("0.00")</strong>
                        </td>

                        <td>
                            @s.PaymentDate.ToString("dd MMM yyyy HH:mm")
                        </td>

                        <td>
                            @if (s.PaymentStatus == "Paid")
                            {
                                <span class="badge bg-success">Paid</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@s.PaymentStatus</span>
                            }
                        </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>
    }

</div>