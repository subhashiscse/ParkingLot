@model Reservation

@{
    ViewData["Title"] = "Payment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <h2>💳 Payment</h2>

    <div class="card shadow-sm p-4">

        <p><strong>Garage:</strong> @Model.GarageName</p>
        <p><strong>Vehicle:</strong> @Model.VehicleName</p>
        <p><strong>Start:</strong> @Model.StartDateTime</p>
        <p><strong>End:</strong> @Model.EndDateTime</p>

        <hr />

        <h4>Total Amount: £@Model.Cost.ToString("0.00")</h4>

        <form asp-action="ConfirmPayment" method="post">

            <input type="hidden" name="reservationId" value="@Model.ReservationId" />

            <button type="submit" class="btn btn-success w-100 mt-3">
                Pay Now
            </button>

        </form>

    </div>

</div>