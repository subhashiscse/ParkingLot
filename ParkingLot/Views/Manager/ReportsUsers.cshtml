@model List<Customer>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <h2>👤 Users Report</h2>

    <table class="table table-hover mt-3">

        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
            </tr>
        </thead>

        <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.CustomerId</td>
                <td>@u.Name</td>
                <td>@u.Email</td>
            </tr>
        }
        </tbody>

    </table>

    <!-- NAVIGATION -->
    <div class="text-center mt-4">

        <a class="btn btn-secondary m-1" href="@Url.Action("Index","Reports")">⬅ Dashboard</a>
        <a class="btn btn-primary m-1" href="@Url.Action("Bookings","Reports")">📅 Reservations</a>
        <a class="btn btn-warning m-1" href="@Url.Action("Vehicles","Reports")">🚗 Vehicles</a>

    </div>

</div>