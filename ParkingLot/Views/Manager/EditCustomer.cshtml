@model Customer

@{
    ViewData["Title"] = "Edit Customer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <h2>✏️ Edit Customer</h2>

    <form asp-action="EditCustomer" asp-controller="Manager" method="post">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="CustomerId" />

        <input asp-for="Name" class="form-control mb-2" placeholder="Name" />
        <span asp-validation-for="Name" class="text-danger"></span>

        <input asp-for="Email" class="form-control mb-2" placeholder="Email" />
        <span asp-validation-for="Email" class="text-danger"></span>

        <input asp-for="PhoneNumber" class="form-control mb-2" placeholder="Phone Number" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>

        <select asp-for="CustomerType" class="form-control mb-2">
            <option value="Customer">Customer</option>
            <option value="VIP">VIP</option>
        </select>

        <input asp-for="BillingAddressLine" class="form-control mb-2" placeholder="Address" />
        <input asp-for="City" class="form-control mb-2" placeholder="City" />
        <input asp-for="Postcode" class="form-control mb-2" placeholder="Postcode" />

        <button type="submit" class="btn btn-primary w-100">
            Update Customer
        </button>

    </form>

</div>