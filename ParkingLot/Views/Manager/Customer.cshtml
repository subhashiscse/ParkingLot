@model List<Customer>

@{
    ViewData["Title"] = "Customers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <h2>👥 Customers</h2>

    <a class="btn btn-primary mb-3"
       href="@Url.Action("CreateCustomer","Manager")">
        ➕ Add Customer
    </a>

    <table class="table table-hover shadow-sm">

        <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Type</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
        </thead>

        <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td>@c.Email</td>
                <td>@c.PhoneNumber</td>
                <td>@c.CustomerType</td>

                <td>
                    @if (c.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </td>

                <td class="d-flex gap-2">

                    <a class="btn btn-sm btn-info"
                       href="@Url.Action("CustomerDetails","Manager", new { id = c.CustomerId })">
                        View
                    </a>

                    <a class="btn btn-sm btn-warning"
                       href="@Url.Action("EditCustomer","Manager", new { id = c.CustomerId })">
                        Edit
                    </a>

                    <a class="btn btn-sm btn-danger"
                       href="@Url.Action("DeleteCustomer","Manager", new { id = c.CustomerId })"
                       onclick="return confirm('Delete this customer?');">
                        Delete
                    </a>

                </td>
            </tr>
        }
        </tbody>

    </table>

</div>