@model VehicleViewModel

@{
    ViewData["Title"] = "Edit Vehicle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">✏️ Edit Vehicle</h2>

<div class="card shadow-sm p-4">

    @using (Html.BeginForm("EditVehicle", "Account", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        @Html.HiddenFor(m => m.VehicleId)

        <div class="mb-3">
            <label>Registration Number</label>
            @Html.TextBoxFor(m => m.RegistrationNumber, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            <label>Make</label>
            @Html.TextBoxFor(m => m.Make, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            <label>Model</label>
            @Html.TextBoxFor(m => m.VehicleModel, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            <label>Colour</label>
            @Html.TextBoxFor(m => m.Colour, new { @class = "form-control" })
        </div>

        <button type="submit" class="btn btn-primary w-100">
            Update Vehicle
        </button>
    }

</div>