@model ProfileViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    var role = Context.Session.GetString("UserRole");
}

<div class="container mt-4">

    <!-- Header -->
    <div class="text-center mb-4">
        <h2 class="fw-bold">👤 My Profile</h2>
        <p class="text-muted">Manage your account details</p>
    </div>

    <!-- Profile Card -->
    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">

                <!-- Top Banner -->
                <div class="card-header bg-primary text-white text-center rounded-top-4">
                    <h4 class="mb-0">Welcome, @Model.Name 👋</h4>
                </div>

                <div class="card-body p-4">

                    <!-- Profile Info -->
                    <div class="mb-3">
                        <label class="text-muted">Name</label>
                        <div class="form-control bg-light">@Model.Name</div>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted">Email</label>
                        <div class="form-control bg-light">@Model.Email</div>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted">Phone</label>
                        <div class="form-control bg-light">@Model.PhoneNumber</div>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted">Address</label>
                        <div class="form-control bg-light">@Model.Address</div>
                    </div>

                </div>

                <!-- Footer Actions -->
                <div class="card-footer bg-white d-flex justify-content-between gap-3">

                    <a href="@Url.Action("EditProfile","Account")"
                       class="btn btn-warning flex-fill">
                        ✏️ Edit Profile
                    </a>
                    @if (role != "Admin")
                    {
                        <a href="@Url.Action("Vehicles","Account")"
                           class="btn btn-primary flex-fill">
                            🚗 My Vehicles
                        </a>
                    }
                </div>

            </div>

        </div>

    </div>

</div>