@model Garage

@{
    ViewData["Title"] = "Garage Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <h2>🅿️ @Model.Name</h2>

    <div class="card shadow-sm p-4">

        <p><strong>Address:</strong> @Model.AddressLine</p>
        <p><strong>City:</strong> @Model.City</p>
        <p><strong>Postcode:</strong> @Model.Postcode</p>
        <p><strong>Total Spaces:</strong> @Model.TotalSpaces</p>
        <p><strong>Remaining Spaces:</strong> @Model.ReminaingSpaces</p>

        <!-- 🚗 BOOK BUTTON -->
        <a class="btn btn-success mt-3"
           href="@Url.Action("Book", "Reservation", new { garageId = Model.GarageId })">
            Book This Garage
        </a>

    </div>

</div>